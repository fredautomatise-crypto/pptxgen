# Copier ce fichier en ".env" et renseigner ta clé.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1

# Modèle utilisé spécifiquement pour le chat d'affinage (avant génération du
# PPTX). Séparé de OPENAI_MODEL : le chat fait beaucoup de petits
# allers-retours, un modèle moins cher suffit largement.
CHAT_MODEL=gpt-4.1-mini

# Nombre de messages d'historique de chat renvoyés à l'API à chaque tour
# (le plan complet est déjà réinjecté à chaque tour, pas besoin de tout
# l'historique pour rester cohérent).
CHAT_HISTORY_MAX_MESSAGES=12

# Plafond de sécurité : arrête proprement si le coût cumulé de la session
# dépasse ce montant (protection contre un bug qui enchaînerait des appels
# à l'infini). 0 ou négatif = pas de limite.
MAX_SESSION_COST_USD=20.0

# Thème visuel par défaut (voir themes/*.json) : default | slate | indigo
THEME=default
